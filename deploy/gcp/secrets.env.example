# Copy to secrets.env and fill — NEVER commit secrets.env
# Used by: ./deploy/gcp/setup-secrets.sh

DATABASE_URL=
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
REDIS_URL=

# Search — production defaults to opensearch (override with SEARCH_ENGINE=postgres-fts)
SEARCH_ENGINE=opensearch
OPENSEARCH_URL=
OPENSEARCH_INDEX=varnarc-search
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
# SEARCH_ENGINE_DUAL_WRITE=false  # opensearch-only writes (skip postgres dual-write)

# AdSense API sync (optional)
ADSENSE_SYNC_ENABLED=false
ADSENSE_OAUTH_CLIENT_ID=
ADSENSE_OAUTH_CLIENT_SECRET=
ADSENSE_OAUTH_REFRESH_TOKEN=
ADSENSE_ACCOUNT_ID=
ADSENSE_CURRENCY=INR

# Multi-region cache invalidation
CACHE_PUBSUB_TOPIC=
CACHE_PUBSUB_SUBSCRIPTION=
CACHE_INVALIDATION_SUBSCRIBE=true

# Observability
PROMETHEUS_ENABLED=false
PROMETHEUS_SCRAPE_TOKEN=
OTEL_ENABLED=false
OTEL_SERVICE_NAME=varnarc-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional — GCS media (Cloud Run uses ADC if SA has storage access)
GCS_BUCKET=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
