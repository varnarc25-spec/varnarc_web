# Apps
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
API_URL=http://localhost:4000/api/v1
API_PORT=4000
WEB_PORT=3000
ADMIN_PORT=3001

# Database (Neon PostgreSQL)
DATABASE_URL=

# Cache / queues (optional locally; recommended staging/production)
REDIS_URL=redis://localhost:6379
RATE_LIMIT_PER_MINUTE=120

# Multi-region cache (optional — see deploy/gcp/multi-region-cache.md)
CACHE_PUBSUB_TOPIC=
CACHE_PUBSUB_SUBSCRIPTION=
CACHE_INVALIDATION_SUBSCRIBE=true

# Search engine (postgres-fts | opensearch)
# Local default: postgres-fts. Production defaults to opensearch when NODE_ENV=production.
SEARCH_ENGINE=postgres-fts
OPENSEARCH_URL=
OPENSEARCH_INDEX=varnarc-search
# Local OpenSearch: docker compose -f docker/docker-compose.infra.yml --profile search up -d
# Then set SEARCH_ENGINE=opensearch and OPENSEARCH_URL=http://localhost:9200

# Google AdSense API sync (optional — revenue dashboard)
# ADSENSE_SYNC_ENABLED=true
# ADSENSE_SYNC_INTERVAL_MS=86400000
# ADSENSE_OAUTH_CLIENT_ID=
# ADSENSE_OAUTH_CLIENT_SECRET=
# ADSENSE_OAUTH_REFRESH_TOKEN=
# ADSENSE_ACCOUNT_ID=accounts/pub-xxxxxxxx
# ADSENSE_CURRENCY=INR

# Google AdSense display (public site — earn from ads)
# 1. Apply at https://www.google.com/adsense and get approved for your domain
# 2. Create ad units in AdSense → Ads → By ad unit
# 3. Set publisher ID + slot IDs below, then restart `pnpm dev`
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_CALCULATOR_SIDEBAR=1234567891
# NEXT_PUBLIC_ADSENSE_SLOT_CALCULATOR_BOTTOM=1234567892
# NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_SIDEBAR=1234567893

# Observability (optional)
PROMETHEUS_ENABLED=false
PROMETHEUS_SCRAPE_TOKEN=
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# Release metadata (set in CI, e.g. git SHA)
APP_VERSION=dev

# Auth0 (required for login — create Regular Web Applications in Auth0 dashboard)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_AUDIENCE=
AUTH0_ISSUER_BASE_URL=
# Auth0 Management API (optional — session revocation in Security Center)
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3000
# Set to "true" after Auth0 apps are configured (shows Login CTA)
NEXT_PUBLIC_AUTH0_CONFIGURED=false

# Auth0 dashboard callbacks to register:
# Web:  http://localhost:3000/auth/callback  | logout: http://localhost:3000
# Admin: http://localhost:3001/auth/callback | logout: http://localhost:3001

# Google Cloud Storage (Media Library)
GCS_BUCKET=
GCS_PROJECT_ID=
# Optional public/CDN base (defaults to https://storage.googleapis.com/<bucket>)
GCS_PUBLIC_BASE_URL=
# Set true only if bucket objects should be publicly readable via makePublic()
GCS_MAKE_PUBLIC=false
# Auth: use one of — ADC (Cloud Run), key file, or service account JSON fields
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=

# Calculator external API allowlist (comma-separated hostnames for type:"api" formulas)
CALCULATOR_API_ALLOWLIST=
EMAIL_FROM=noreply@varnarc.com

# AI content generation (admin article writer — OpenAI-compatible API)
# Cursor Pro is for the IDE; set an API key here for in-app generation.
OPENAI_API_KEY=
AI_DEFAULT_MODEL=gemini-flash-latest
# Optional: use OpenRouter, Azure OpenAI, or local LM Studio
# AI_BASE_URL=https://api.openai.com/v1
