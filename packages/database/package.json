{
  "name": "@varnarc/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "generate": "prisma generate --schema=prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "seed:homepage": "tsx --env-file=../../.env src/seed-homepage-only.ts",
    "seed:calculator-articles": "tsx --env-file=../../.env src/seed-calculator-articles-only.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@varnarc/auth": "workspace:^"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
