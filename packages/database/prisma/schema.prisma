  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("USD")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  @@index([paymentId, createdAt])
  @@map("transactions")
}

model Language {
