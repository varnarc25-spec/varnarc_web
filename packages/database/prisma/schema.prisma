generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING
  DELETED
  @@map("user_status")
}

enum PublishStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
  @@map("publish_status")
}

enum MediaResourceType {
  IMAGE
  VIDEO
  RAW
  DOCUMENT
  @@map("media_resource_type")
}

enum AdStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  ENDED
  ARCHIVED
  @@map("ad_status")
}

enum AdType {
  ADSENSE
  BANNER
  HTML
  JAVASCRIPT
  AFFILIATE
  SPONSORED
  NATIVE
  CTA
  INTERNAL
  @@map("ad_type")
}

enum AdProvider {
  GOOGLE_ADSENSE
  DIRECT
  AFFILIATE
  INTERNAL
  @@map("ad_provider")
}

enum AdContentType {
  IMAGE
  HTML
  JAVASCRIPT
  TEXT
  SCRIPT_SLOT
  @@map("ad_content_type")
}

enum AdRotationMode {
  SEQUENTIAL
  RANDOM
  WEIGHTED
  PRIORITY
  @@map("ad_rotation_mode")
}

enum CalculationStatus {
  SUCCESS
  FAILED
  PENDING
  @@map("calculation_status")
}

enum AiJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  @@map("ai_job_status")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  @@map("notification_channel")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  @@map("subscription_status")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  @@map("payment_status")
}

enum BusinessStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  @@map("business_status")
}

enum ListingType {
  FREE
  VERIFIED
  FEATURED
  SPONSORED
  PREMIUM
  @@map("listing_type")
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
  @@map("verification_status")
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
  @@map("lead_status")
}

enum DirectoryEventType {
  VIEW
  PROFILE_CLICK
  WEBSITE_CLICK
  PHONE_CLICK
  WHATSAPP_CLICK
  EMAIL_CLICK
  LEAD_REQUEST
  SEARCH
  @@map("directory_event_type")
}

enum AiPricingModel {
  FREE
  FREEMIUM
  SUBSCRIPTION
  PAY_AS_YOU_GO
  ENTERPRISE
  LIFETIME
  @@map("ai_pricing_model")
}

enum AiToolEventType {
  VIEW
  OUTBOUND_CLICK
  AFFILIATE_CLICK
  BOOKMARK
  SEARCH
  COMPARE
  @@map("ai_tool_event_type")
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  auth0UserId   String     @unique @map("auth0_user_id")
  username      String?    @unique
  email         String     @unique
  firstName     String?    @map("first_name")
  lastName      String?    @map("last_name")
  displayName   String?    @map("display_name")
  avatarUrl     String?    @map("avatar_url")
  avatarMediaId String?    @map("avatar_media_id") @db.Uuid
  bio           String?
  phone         String?
  country       String?
  state         String?
  city          String?
  language      String?
  timezone      String?
  website       String?
  socialLinks   Json?      @map("social_links")
  profileVisibility ProfileVisibility @default(PUBLIC) @map("profile_visibility")
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false) @map("email_verified")
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")
  createdBy     String?    @map("created_by") @db.Uuid
  updatedBy     String?    @map("updated_by") @db.Uuid

  roles             UserRole[]
  loginHistory      LoginHistory[]
  auditLogs         AuditLog[]
  securityEvents    SecurityEvent[]
  articles          Article[]           @relation("ArticleAuthor")
  comments          Comment[]
  savedCalculations SavedCalculation[]
  subscriptions     Subscription[]
  notifications     UserNotification[]
  pageViews         PageView[]
  reviews           Review[]            @relation("ReviewAuthor")
  userReviews       UserReview[]
  businesses        Business[]          @relation("BusinessOwner")
  businessReviews   BusinessReview[]
  leadRequests      LeadRequest[]
  aiJobs            AiJob[]
  bookmarks         Bookmark[]
  preferences       UserPreference?
  activities        UserActivity[]
  contentSubscriptions UserContentSubscription[]
  aiToolBookmarks   AiToolBookmark[]
  aiToolViews       AiToolRecentlyViewed[]
  aiCategoryFollows AiCategoryFollow[]

  @@index([status])
  @@index([createdAt])
  @@index([username])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  slug        String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  createdBy   String?          @map("created_by") @db.Uuid
  updatedBy   String?          @map("updated_by") @db.Uuid
  users       UserRole[]
  permissions RolePermission[]
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  slug        String           @unique
  name        String
  module      String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  createdBy   String?          @map("created_by") @db.Uuid
  updatedBy   String?          @map("updated_by") @db.Uuid
  roles       RolePermission[]
  @@index([module])
  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at")
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model LoginHistory {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  ipAddress       String?  @map("ip_address")
  device          String?
  browser         String?
  operatingSystem String?  @map("operating_system")
  country         String?
  loginTime       DateTime @default(now()) @map("login_time")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, loginTime])
  @@map("login_history")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([entity, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model SecurityEvent {
  id          String   @id @default(uuid()) @db.Uuid
  eventType   String   @map("event_type")
  severity    String   @default("info")
  description String
  status      String   @default("open")
  userId      String?  @map("user_id") @db.Uuid
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([eventType, createdAt])
  @@index([severity, status])
  @@index([userId, createdAt])
  @@map("security_events")
}

model Bookmark {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  entityType     String    @map("entity_type")
  entityId       String    @map("entity_id") @db.Uuid
  collectionName String?   @map("collection_name")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([userId, collectionName])
  @@map("bookmarks")
}

model UserPreference {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  theme                String?
  language             String?
  timezone             String?
  notificationSettings Json?    @map("notification_settings")
  privacySettings      Json?    @map("privacy_settings")
  newsletterOptIn      Boolean  @default(false) @map("newsletter_opt_in")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("user_preferences")
}

model UserActivity {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  activityType String   @map("activity_type")
  entityType   String?  @map("entity_type")
  entityId     String?  @map("entity_id") @db.Uuid
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@map("user_activity")
}

model UserContentSubscription {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  subscriptionType String   @map("subscription_type")
  target           String
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, subscriptionType, target])
  @@index([userId])
  @@map("user_content_subscriptions")
}

model Setting {
  id        String    @id @default(uuid()) @db.Uuid
  key       String    @unique
  value     Json
  group     String    @default("general")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  @@index([group])
  @@map("settings")
}

model FeatureFlag {
  id          String    @id @default(uuid()) @db.Uuid
  key         String    @unique
  name        String
  description String?
  enabled     Boolean   @default(false)
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  @@map("feature_flags")
}

model Theme {
  id                String       @id @default(uuid()) @db.Uuid
  slug              String       @unique
  name              String
  description       String?
  tokens            Json
  fonts             Json?
  colors            Json?
  branding          Json?
  cssVars           Json?        @map("css_vars")
  isDefault         Boolean      @default(false) @map("is_default")
  isSystem          Boolean      @default(false) @map("is_system")
  tenantKey         String?      @map("tenant_key")
  season            String?
  scheduledFrom     DateTime?    @map("scheduled_from")
  scheduledUntil    DateTime?    @map("scheduled_until")
  marketplaceListed Boolean      @default(false) @map("marketplace_listed")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")
  createdBy         String?      @map("created_by") @db.Uuid
  updatedBy         String?      @map("updated_by") @db.Uuid
  assets            ThemeAsset[]
  @@index([tenantKey])
  @@index([marketplaceListed])
  @@index([scheduledFrom, scheduledUntil])
  @@map("themes")
}

model ThemeAsset {
  id        String      @id @default(uuid()) @db.Uuid
  themeId   String      @map("theme_id") @db.Uuid
  type      String
  mediaId   String?     @map("media_id") @db.Uuid
  url       String?
  createdAt DateTime    @default(now()) @map("created_at")
  theme     Theme       @relation(fields: [themeId], references: [id], onDelete: Cascade)
  media     MediaAsset? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  @@unique([themeId, type])
  @@index([themeId])
  @@map("theme_assets")
}

model Menu {
  id        String     @id @default(uuid()) @db.Uuid
  slug      String     @unique
  name      String
  location  String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  createdBy String?    @map("created_by") @db.Uuid
  updatedBy String?    @map("updated_by") @db.Uuid
  items     MenuItem[]
  @@index([location])
  @@map("menus")
}

model MenuItem {
  id        String     @id @default(uuid()) @db.Uuid
  menuId    String     @map("menu_id") @db.Uuid
  parentId  String?    @map("parent_id") @db.Uuid
  label     String
  href      String?
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  createdBy String?    @map("created_by") @db.Uuid
  updatedBy String?    @map("updated_by") @db.Uuid
  menu     Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent   MenuItem?  @relation("MenuItemTree", fields: [parentId], references: [id])
  children MenuItem[] @relation("MenuItemTree")
  @@index([menuId, sortOrder])
  @@map("menu_items")
}
model MediaFolder {
  id        String        @id @default(uuid()) @db.Uuid
  parentId  String?       @map("parent_id") @db.Uuid
  name      String
  slug      String
  path      String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")
  createdBy String?       @map("created_by") @db.Uuid
  updatedBy String?       @map("updated_by") @db.Uuid
  parent   MediaFolder?  @relation("MediaFolderTree", fields: [parentId], references: [id])
  children MediaFolder[] @relation("MediaFolderTree")
  assets   MediaAsset[]
  @@unique([parentId, slug])
  @@map("media_folders")
}

model MediaAlbum {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  slug        String            @unique
  description String?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")
  createdBy   String?           @map("created_by") @db.Uuid
  updatedBy   String?           @map("updated_by") @db.Uuid
  assets      MediaAlbumAsset[]
  @@map("media_albums")
}

model MediaTag {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  slug      String          @unique
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  deletedAt DateTime?       @map("deleted_at")
  assets    MediaAssetTag[]
  @@map("media_tags")
}

model MediaAsset {
  id           String            @id @default(uuid()) @db.Uuid
  folderId     String?           @map("folder_id") @db.Uuid
  publicId     String            @unique @map("public_id")
  url          String
  secureUrl    String            @map("secure_url")
  resourceType MediaResourceType @default(IMAGE) @map("resource_type")
  originalName String?           @map("original_name")
  fileName     String?           @map("file_name")
  mimeType     String?           @map("mime_type")
  format       String?
  bytes        Int?
  width        Int?
  height       Int?
  duration     Int?
  thumbnailUrl String?           @map("thumbnail_url")
  alt          String?
  caption      String?
  description  String?
  metadata     Json?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  deletedAt    DateTime?         @map("deleted_at")
  createdBy    String?           @map("created_by") @db.Uuid
  updatedBy    String?           @map("updated_by") @db.Uuid
  folder      MediaFolder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  versions    MediaAssetVersion[]
  albums      MediaAlbumAsset[]
  tags        MediaAssetTag[]
  usage       MediaUsage[]
  articles    Article[]          @relation("ArticleFeaturedImage")
  themeAssets ThemeAsset[]
  @@index([folderId])
  @@index([resourceType])
  @@map("media_assets")
}

model MediaUsage {
  id         String     @id @default(uuid()) @db.Uuid
  assetId    String     @map("asset_id") @db.Uuid
  entityType String     @map("entity_type")
  entityId   String     @map("entity_id") @db.Uuid
  fieldName  String?    @map("field_name")
  createdAt  DateTime   @default(now()) @map("created_at")
  asset      MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@unique([assetId, entityType, entityId, fieldName])
  @@index([assetId])
  @@map("media_usage")
}

model MediaAssetVersion {
  id        String     @id @default(uuid()) @db.Uuid
  assetId   String     @map("asset_id") @db.Uuid
  url       String
  width     Int?
  height    Int?
  label     String?
  createdAt DateTime   @default(now()) @map("created_at")
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId])
  @@map("media_asset_versions")
}

model MediaAlbumAsset {
  albumId   String @map("album_id") @db.Uuid
  assetId   String @map("asset_id") @db.Uuid
  sortOrder Int    @default(0) @map("sort_order")
  album MediaAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@id([albumId, assetId])
  @@map("media_album_assets")
}

model MediaAssetTag {
  assetId String @map("asset_id") @db.Uuid
  tagId   String @map("tag_id") @db.Uuid
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   MediaTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([assetId, tagId])
  @@map("media_asset_tags")
}

model Category {
  id          String        @id @default(uuid()) @db.Uuid
  parentId    String?       @map("parent_id") @db.Uuid
  name        String
  slug        String        @unique
  description String?
  status      PublishStatus @default(DRAFT)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")
  createdBy   String?       @map("created_by") @db.Uuid
  updatedBy   String?       @map("updated_by") @db.Uuid
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  articles Article[]
  @@index([status, slug])
  @@map("categories")
}

model Tag {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  articles  ArticleTag[]
  @@map("tags")
}

model Article {
  id              String        @id @default(uuid()) @db.Uuid
  authorId        String        @map("author_id") @db.Uuid
  categoryId      String?       @map("category_id") @db.Uuid
  featuredImageId String?       @map("featured_image_id") @db.Uuid
  title           String
  slug            String        @unique
  excerpt         String?
  content         String
  status          PublishStatus @default(DRAFT)
  publishedAt     DateTime?     @map("published_at")
  isFeatured      Boolean       @default(false) @map("is_featured")
  readingTimeMinutes Int?       @map("reading_time_minutes")
  metadata        Json?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  createdBy       String?       @map("created_by") @db.Uuid
  updatedBy       String?       @map("updated_by") @db.Uuid
  author        User             @relation("ArticleAuthor", fields: [authorId], references: [id])
  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  featuredImage MediaAsset?      @relation("ArticleFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  versions      ArticleVersion[]
  tags          ArticleTag[]
  comments      Comment[]
  relatedFrom   ArticleRelated[] @relation("ArticleRelatedFrom")
  relatedTo     ArticleRelated[] @relation("ArticleRelatedTo")
  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([authorId, publishedAt])
  @@index([isFeatured, status])
  @@map("articles")
}

model ArticleRelated {
  articleId String @map("article_id") @db.Uuid
  relatedId String @map("related_id") @db.Uuid
  sortOrder Int    @default(0) @map("sort_order")
  article Article @relation("ArticleRelatedFrom", fields: [articleId], references: [id], onDelete: Cascade)
  related Article @relation("ArticleRelatedTo", fields: [relatedId], references: [id], onDelete: Cascade)
  @@id([articleId, relatedId])
  @@index([articleId, sortOrder])
  @@map("article_related")
}

model PageVersion {
  id        String   @id @default(uuid()) @db.Uuid
  pageId    String   @map("page_id") @db.Uuid
  title     String
  content   String?
  version   Int
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.Uuid
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  @@unique([pageId, version])
  @@map("page_versions")
}

model ArticleVersion {
  id        String   @id @default(uuid()) @db.Uuid
  articleId String   @map("article_id") @db.Uuid
  title     String
  content   String
  version   Int
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.Uuid
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  @@unique([articleId, version])
  @@map("article_versions")
}

model ArticleTag {
  articleId String @map("article_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([articleId, tagId])
  @@map("article_tags")
}

model Comment {
  id        String        @id @default(uuid()) @db.Uuid
  articleId String        @map("article_id") @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
