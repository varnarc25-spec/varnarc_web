enum SearchEntityType {
  ARTICLE
  PAGE
  CMS_CATEGORY
  TAG
  GUIDE
  LOAN
  BANK
  CREDIT_CARD
  INSURANCE
  MATERIAL
  BRAND
  VEHICLE
  MANUFACTURER
  DEALER
  BUSINESS
  BUSINESS_SERVICE
  VENDOR
  AI_TOOL
  AI_CATEGORY
  CALCULATOR
  FORMULA_PAGE
  REVIEW
  COMPARISON
  MEDIA
  @@map("search_entity_type")
}

model SearchIndex {
  id             String           @id @default(uuid()) @db.Uuid
  entityType     SearchEntityType @map("entity_type")
  entityId       String           @map("entity_id") @db.Uuid
  title          String
  summary        String?
  content        String?
  keywords       String?
  tags           String?
  slug           String
  url            String
  thumbnail      String?
  category       String?
  location       String?
  author         String?
  brand          String?
  priceMin       Decimal?         @map("price_min") @db.Decimal(12, 2)
  priceMax       Decimal?         @map("price_max") @db.Decimal(12, 2)
  vehicleType    String?          @map("vehicle_type")
  fuelType       String?          @map("fuel_type")
  loanType       String?          @map("loan_type")
  materialType   String?          @map("material_type")
  seoTitle       String?          @map("seo_title")
  seoDescription String?          @map("seo_description")
  language       String           @default("en")
  status         PublishStatus    @default(PUBLISHED)
  featured       Boolean          @default(false)
  sponsored      Boolean          @default(false)
  verified       Boolean          @default(false)
  rating         Float?
  viewCount      Int              @default(0) @map("view_count")
  publishedAt    DateTime?        @map("published_at")
  searchVector   Unsupported("tsvector")? @map("search_vector")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@unique([entityType, entityId])
  @@index([entityType, status])
  @@index([category])
  @@index([publishedAt])
  @@index([slug])
  @@index([location])
  @@index([brand])
  @@index([rating])
  @@map("search_index")
}

model SearchQuery {
  id          String   @id @default(uuid()) @db.Uuid
  query       String
  results     Int?
  clicked     Boolean  @default(false)
  latencyMs   Int?     @map("latency_ms")
  userId      String?  @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  resultClicks SearchResultClick[]
  @@index([query])
  @@index([createdAt])
  @@index([results])
  @@map("search_queries")
}

model SearchResultClick {
  id         String            @id @default(uuid()) @db.Uuid
  queryId    String?           @map("query_id") @db.Uuid
  entityType SearchEntityType  @map("entity_type")
  entityId   String            @map("entity_id") @db.Uuid
  url        String?
  createdAt  DateTime          @default(now()) @map("created_at")
  query      SearchQuery?      @relation(fields: [queryId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([queryId])
  @@map("search_result_clicks")
}

model PopularSearch {
  id          String   @id @default(uuid()) @db.Uuid
