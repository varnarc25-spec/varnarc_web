  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([statusCode, createdAt])
