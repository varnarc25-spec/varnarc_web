{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "types": ["node"],
    "strictPropertyInitialization": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/**/*"]
}
